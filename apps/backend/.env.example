# Database
# Local dev (Docker/default)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dairy_farm"

# Optional (recommended for Neon + Prisma):
# - DATABASE_URL: use the POOLED connection string (host usually contains `-pooler`)
# - DIRECT_URL: use the DIRECT connection string (no `-pooler`) for migrations
#
# Example:
# DATABASE_URL="postgresql://USER:PASSWORD@YOUR-DB-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@YOUR-DB.REGION.aws.neon.tech/DB?sslmode=require"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRATION="7d"

# Server
PORT=3001
NODE_ENV=development
