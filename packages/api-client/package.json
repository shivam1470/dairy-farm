{
  "name": "@dairy-farm/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "openapi"
  ],
  "scripts": {
    "clean": "rm -rf dist openapi",
    "generate": "pnpm run generate:types",
    "generate:spec": "node ./scripts/download-openapi-spec.cjs",
    "generate:types": "openapi-typescript $OPENAPI_URL -o openapi/schema.d.ts",
    "generate:types:file": "openapi-typescript openapi/openapi.json -o openapi/schema.d.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "echo 'no lint'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'no tests'"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.8"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.3.3"
  }
}
